---
import AcademicLayout from '../layouts/AcademicLayout.astro'
import profile from '../data/profile.json'
import newsData from '../data/news.json'
import publicationsData from '../data/publications.json'

const recentNews = [...newsData.items]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3)

const recentPublications = [...publicationsData.items]
  .filter((item) => {
    const firstAuthor = item?.authors?.[0]?.trim()?.toLowerCase()
    return firstAuthor === 'da kong' || firstAuthor === 'd. kong'
  })
  .sort((a, b) => b.year - a.year)
  .slice(0, 3)

const typeLabel = {
  conference: 'Conference',
  journal: 'Journal',
  other: 'Other',
}
const formatNewsDate = (value) => {
  const date = new Date(`${value}T00:00:00`)
  if (Number.isNaN(date.getTime())) return value
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: '2-digit',
    year: 'numeric',
  })
}

const newsDateClass = 'news-time text-[11px] tracking-[0.12em] font-medium font-ui'
const newsTextClass = 'max-w-3xl text-base leading-8 text-slate-900 font-academic'
const newsTitleClass = 'mt-2 font-display text-3xl leading-tight text-slate-900 tracking-tight'
const newsSubClass = 'mt-1 text-sm leading-relaxed text-slate-600'
---

<AcademicLayout title="Home" description="Academic homepage for Da Kong.">
  <section class="grid gap-8 md:grid-cols-[1.5fr_1fr]">
    <div>
      <p class="section-title">Academic homepage</p>
      <h1 class="mt-2 font-display text-4xl font-semibold leading-tight text-slate-900">{profile.nameDisplay}</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-700">{profile.title}</p>
      <p class="mt-2 text-slate-600">{profile.organization}</p>

      <div class="mt-6 space-y-3 text-slate-700">
        {profile.summary.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/about" class="rounded-full bg-slate-900 px-5 py-2 text-white">About</a>
        <a href="/publications" class="rounded-full border border-slate-300 px-5 py-2">Publications</a>
      </div>
    </div>

    <aside class="card">
      <img src={profile.avatar} alt={profile.nameDisplay} class="mb-5 h-32 w-32 rounded-full border border-slate-100 object-cover" />
      <p class="font-medium">Research Interests</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {profile.researchInterests.map((item) => <span class="chip">{item}</span>)}
      </div>
      <p class="mt-4 text-sm text-slate-600">Location: {profile.location}</p>
      <div class="mt-4 space-y-2 text-sm">
        {Object.entries(profile.links).map(([label, href]) => (
          <p>
            <a class="font-medium text-slate-700 hover:text-slate-900" href={href} target="_blank" rel="noreferrer">{label}</a>
          </p>
        ))}
      </div>
    </aside>
  </section>

  <div class="section-rule mt-8 border-t border-slate-200 pt-7">
    <div class="mt-7 space-y-7">
    <section>
      <div class="mb-3 border-b border-slate-200 pb-3">
        <p class="section-title">News</p>
        <p class={newsTitleClass}>Research Updates</p>
        <p class={newsSubClass}>Selected notes on recent research progress and announcements.</p>
      </div>
      <div>
        <div class="timeline">
          {recentNews.map((newsItem, index) => (
            <article class="timeline-item relative pb-6 last:pb-1">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <time class={newsDateClass}>{formatNewsDate(newsItem.date)}</time>
                {index === 0 ? <span class="rounded-full border border-slate-900/20 bg-slate-900/5 px-2.5 py-1 text-[11px] font-medium tracking-wide text-slate-700">Latest</span> : null}
              </div>
              <p class={newsTextClass}>{newsItem.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section>
      <div class="mb-4 border-b border-slate-200 pb-4">
      <div class="mb-3 border-b border-slate-200 pb-3">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="section-title">Publications</p>
            <p class="mt-2 font-display text-3xl font-semibold leading-tight text-slate-900">Recent Publications</p>
            <p class="mt-1 text-sm text-slate-500">Curated from the latest release of my publication list.</p>
          </div>
          <a href="/publications" class="inline-flex h-fit rounded-full border border-slate-900 px-3 py-1 text-xs font-semibold tracking-wide text-slate-800 transition-colors hover:bg-slate-900 hover:text-white">
            View all
          </a>
        </div>
      </div>

      <section>
        <div class="overflow-x-auto">
          <table class="min-w-full border-collapse">
            <thead>
              <tr class="text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                <th class="border-b border-slate-200 py-3 pr-4">Year</th>
                <th class="border-b border-slate-200 py-3 pr-4">Type</th>
                <th class="border-b border-slate-200 py-3 pr-4">Title</th>
                <th class="border-b border-slate-200 py-3 pr-4">Venue</th>
              </tr>
            </thead>
            <tbody>
              {recentPublications.map((item) => (
                <tr class="border-b border-slate-100 last:border-b-0 hover:bg-slate-50/70">
                  <td class="py-3 pr-4 align-top text-sm font-semibold text-slate-700">{item.year}</td>
                  <td class="py-3 pr-4 align-top text-sm text-slate-700">{typeLabel[item.type] || item.type}</td>
                <td class="max-w-lg py-3 pr-4 align-top text-sm font-medium leading-6 text-slate-900">{item.title}</td>
                <td class="py-3 pr-4 align-top text-sm text-slate-700">
                  <p>{item.venue}</p>
                </td>
              </tr>
            ))}
          </tbody>
          </table>
        </div>
      </section>
    </section>
  </div>
</div>
</AcademicLayout>
