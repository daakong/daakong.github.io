---
import AcademicLayout from '../layouts/AcademicLayout.astro'
---

<AcademicLayout title="404" description="Page not found">
  <div class="card max-w-2xl">
    <p class="text-4xl font-semibold">404</p>
    <h1 class="mt-2 font-display text-3xl font-semibold">Page not found</h1>
    <p class="mt-3 text-slate-700">The requested page cannot be found. Use the menu above to go to the academic homepage.</p>
    <a href="/" class="mt-6 inline-flex rounded-full bg-slate-900 px-5 py-2 text-white">Back to Home</a>
  </div>
</AcademicLayout>
