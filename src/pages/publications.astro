---
import AcademicLayout from '../layouts/AcademicLayout.astro'
import SectionTitle from '../components/SectionTitle.astro'
import publicationsData from '../data/publications.json'

const allItems = [...publicationsData.items].sort((a, b) => b.year - a.year)
const total = allItems.length

const filters = [
  { label: 'All', value: 'all' },
  { label: 'Journal', value: 'journal' },
  { label: 'Conference', value: 'conference' },
  { label: 'Other', value: 'other' },
]

const filterHref = (value) => (value === 'all' ? '/publications' : `/publications/${value}`)
const typeLabel = {
  conference: 'Conference',
  journal: 'Journal',
  other: 'Other',
}
---

<AcademicLayout title="Publications" description="Publications list for Da Kong.">
  <SectionTitle title="Publications" subtitle={`All ${total} publication records`} />

  <div class="mb-6 flex flex-wrap gap-2">
    {filters.map((filter) => (
      <a
        href={filterHref(filter.value)}
        data-publication-filter={filter.value}
        class:list={[
          'rounded-full px-3 py-1 text-sm',
          filter.value === 'all'
            ? 'bg-slate-900 text-white'
            : 'border border-slate-200 text-slate-700',
        ]}
      >
        {filter.label}
      </a>
    ))}
  </div>

  <section id="publication-empty" class="card hidden">
    <p class="text-sm text-slate-700">
      No publications in this category yet. Choose another filter to see more.
    </p>
  </section>

  <section id="publication-table" class="card">
    <p id="publication-result-count" class="mb-4 text-sm text-slate-700">{`All ${total} publication records`}</p>
    <div class="overflow-x-auto">
      <table class="min-w-full border-collapse">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wide text-slate-500">
            <th class="border-b border-slate-200 py-3 pr-4">Year</th>
            <th class="border-b border-slate-200 py-3 pr-4">Type</th>
            <th class="border-b border-slate-200 py-3 pr-4">Title</th>
            <th class="border-b border-slate-200 py-3 pr-4">Authors</th>
            <th class="border-b border-slate-200 py-3 pr-4">Venue</th>
            <th class="border-b border-slate-200 py-3">Links</th>
          </tr>
        </thead>
        <tbody>
          {allItems.map((item) => (
            <tr data-publication-row data-type={item.type} class="border-b border-slate-100 last:border-b-0">
              <td class="py-3 pr-4 align-top text-sm font-medium">{item.year}</td>
              <td class="py-3 pr-4 align-top text-sm">{typeLabel[item.type] || item.type}</td>
              <td class="max-w-lg py-3 pr-4 align-top text-sm font-medium text-slate-900">{item.title}</td>
              <td class="py-3 pr-4 align-top text-sm text-slate-700">
                {item.authors.map((author, index) => (
                  <span>
                    {author === 'Da Kong' ? <strong>{author}</strong> : author}
                    {index < item.authors.length - 1 ? ', ' : ''}
                  </span>
                ))}
              </td>
                <td class="py-3 pr-4 align-top text-sm text-slate-700">
                  <p>{item.venue}</p>
                </td>
                <td class="py-3 align-top">
                  {item.links && item.links.length ? (
                    <div class="flex flex-wrap gap-2">
                    {item.links.map((link) => (
                      <a
                        class="rounded-full border border-slate-200 px-3 py-1 text-xs"
                        href={link.href}
                        target="_blank"
                        rel="noreferrer"
                      >
                        {link.label}
                      </a>
                      ))}
                    </div>
                  ) : (
                    <span class="text-xs text-slate-400">—</span>
                  )}
                </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script is:inline>
    (() => {
      const validTypes = new Set(['all', 'conference', 'journal', 'other'])
      const buttons = Array.from(document.querySelectorAll('[data-publication-filter]'))
      const rows = Array.from(document.querySelectorAll('[data-publication-row]'))
      const total = rows.length
      const resultCount = document.getElementById('publication-result-count')
      const tableSection = document.getElementById('publication-table')
      const emptySection = document.getElementById('publication-empty')

      const getActiveTypeFromUrl = () => {
        const current = new URL(window.location.href)
        const fromPath = current.pathname.match(/^\/publications\/(journal|conference|other)\/?$/)
        const queryType = current.searchParams.get('type')
        const normalized = (fromPath ? fromPath[1] : (queryType ? queryType.toLowerCase() : 'all'))
        return validTypes.has(normalized) ? normalized : 'all'
      }

      const updateFilterButtons = (type) => {
        buttons.forEach((button) => {
          const isActive = button.dataset.publicationFilter === type
          button.classList.toggle('bg-slate-900', isActive)
          button.classList.toggle('text-white', isActive)
          button.classList.toggle('border', !isActive)
          button.classList.toggle('border-slate-200', !isActive)
          button.classList.toggle('text-slate-700', !isActive)
        })
      }

      const applyFilter = (type) => {
        const currentType = validTypes.has(type) ? type : 'all'
        let shown = 0

        rows.forEach((row) => {
          const match = currentType === 'all' || row.dataset.type === currentType
          row.style.display = match ? '' : 'none'
          if (match) shown += 1
        })

        if (resultCount) {
          resultCount.textContent = shown === total ? `All ${total} publication records` : `Showing ${shown} of ${total} publication records`
        }
        if (emptySection && tableSection) {
          emptySection.classList.toggle('hidden', shown > 0)
          tableSection.classList.toggle('hidden', shown === 0)
        }

        updateFilterButtons(currentType)
      }

      buttons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault()
          const filterType = button.dataset.publicationFilter || 'all'
          const nextUrl = new URL(window.location.href)
          if (filterType === 'all') {
            nextUrl.pathname = '/publications'
            nextUrl.searchParams.delete('type')
          } else {
            nextUrl.pathname = `/publications/${filterType}`
            nextUrl.searchParams.delete('type')
          }
          window.history.replaceState({}, '', nextUrl)
          applyFilter(filterType)
        })
      })

      applyFilter(getActiveTypeFromUrl())
    })()
  </script>
</AcademicLayout>
