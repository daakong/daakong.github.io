---
const { item } = Astro.props

const authors = item.authors || []
---
<article class="card">
  <div class="flex flex-wrap items-baseline justify-between gap-3">
    <h3 class="max-w-2xl font-display text-lg font-semibold text-slate-900">{item.title}</h3>
    <span class="chip">{item.year}</span>
  </div>
  <p class="mt-2 text-sm text-slate-700">
    {authors.map((author, index) => (
      <span>
        {author === 'Da Kong' ? <strong>{author}</strong> : author}
        {index < authors.length - 1 ? ', ' : ''}
      </span>
    ))}
  </p>
  <p class="mt-2 text-sm text-slate-600">
    {item.venue} {item.note ? `(${item.note})` : ''} {item.month ? `, ${item.month}` : ''}
  </p>
  {item.links?.length ? (
    <div class="mt-3 flex flex-wrap gap-2">
      {item.links.map((link) => (
        <a class="chip" href={link.href} target="_blank" rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  ) : null}
</article>
